# Development defaults. Production must set NODE_ENV=production and provide
# non-example secrets through the deployment secret manager.
NODE_ENV=development
WEB_PORT=33000
API_PORT=34000
API_BASE_URL=http://localhost:34000
NEXT_PUBLIC_API_BASE_URL=http://localhost:34000
# Browser API routing mode. Use same-origin only for self-hosted/Docker web images that proxy /api.
OPEN_PRACTICE_BROWSER_API_MODE=external
DATABASE_URL=postgresql://open_practice:open_practice@localhost:35432/open_practice
OPEN_PRACTICE_USE_MEMORY_REPO=false
OPEN_PRACTICE_DEV_SEED=true
DEV_AUTH_FIRM_ID=firm-west-legal
DEV_AUTH_USER_ID=user-admin
WEBAUTHN_ORIGIN=http://localhost:33000
PUBLIC_WEB_BASE_URL=http://localhost:33000
# Compose-only browser origins for alternate local host ports. Keep these loopback-only.
OPEN_PRACTICE_PUBLIC_WEB_ORIGIN=http://localhost:33000
OPEN_PRACTICE_PUBLIC_API_ORIGIN=http://localhost:34000
# Development only. Production requires a unique secret of at least 32 characters.
AUTH_JWT_SECRET=dev-only-change-me-at-least-16-chars
SESSION_TTL_HOURS=12

# Optional public website consultation intake bridge. Allowed origins also feed CORS for the
# unauthenticated public submission route; sender/recipient/enabled values bootstrap the firm-owned
# provider setting when explicitly supplied.
PUBLIC_CONSULTATION_INTAKE_ALLOWED_ORIGINS=http://localhost:4321
PUBLIC_CONSULTATION_INTAKE_ENABLED=
PUBLIC_CONSULTATION_INTAKE_SENDER_ADDRESS=
PUBLIC_CONSULTATION_INTAKE_RECIPIENT_EMAILS=
PUBLIC_CONSULTATION_INTAKE_FIRM_ID=
PUBLIC_CONSULTATION_INTAKE_ACTOR_USER_ID=
PUBLIC_CONSULTATION_INTAKE_REVIEW_OWNER_USER_ID=
# Hash only. Generate or rotate the raw token in staff settings; do not store raw tokens in env.
PUBLIC_CONSULTATION_INTAKE_SUBMISSION_TOKEN_HASH=

# Queue and worker runtime. Redis is execution state; PostgreSQL stores legal/audit-relevant state.
REDIS_URL=redis://localhost:36379/0
WORKER_QUEUES=email,inbound_email,ai_triage,ocr,transcription,media
WORKER_CONCURRENCY=2
# Optional JSON map for connector webhook signing secrets. Prefer staff settings where available.
CONNECTOR_WEBHOOK_SECRETS=

# Optional S3-compatible storage. Set endpoint, access key, and secret key together.
S3_ENDPOINT=http://localhost:39000
S3_REGION=local
S3_BUCKET=open-practice-documents
S3_ACCESS_KEY=open_practice
S3_SECRET_KEY=open_practice_secret
# Optional locally; required as AES256 in production when S3 is configured.
S3_SERVER_SIDE_ENCRYPTION=

# SMTP and IMAP provider credentials are configured in first-run setup or Admin email settings.
# For local SMTP capture, use Mailpit host localhost and port 31025 from the dashboard form.

# Optional hosted meeting links. Set both values together to enable Hosted WebRTC room URLs.
WEBRTC_MEETING_PROVIDER_KEY=
WEBRTC_MEETING_BASE_URL=

# Optional inbound email and local AI. Both are disabled until configured during setup.
INBOUND_EMAIL_WEBHOOK_SECRET=
INBOUND_EMAIL_DOMAIN=
AI_PROVIDER=disabled
AI_ENDPOINT=http://localhost:11434/v1
AI_MODEL=
OCR_DEFAULT_LANGUAGE=eng
OCR_CONFIDENCE_THRESHOLD=70
WHISPER_MODEL=
MEDIA_TEMP_DIR=.tmp/open-practice-media

# Required for PostgreSQL-backed API and worker runtimes. Use a 32-byte base64, base64url, or hex key.
OPEN_PRACTICE_CONFIG_ENCRYPTION_KEY=
