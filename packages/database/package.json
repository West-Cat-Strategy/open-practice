{
  "name": "@open-practice/database",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./config-encryption": {
      "types": "./dist/config-encryption.d.ts",
      "default": "./dist/config-encryption.js"
    },
    "./repository": {
      "types": "./dist/repository.d.ts",
      "default": "./dist/repository.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "default": "./dist/runtime.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "default": "./dist/schema.js"
    },
    "./seed": {
      "types": "./dist/seed.d.ts",
      "default": "./dist/seed.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "db:check": "drizzle-kit check",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@open-practice/domain": "workspace:^",
    "drizzle-orm": "0.45.2",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "drizzle-kit": "^0.31.10",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1"
  }
}
