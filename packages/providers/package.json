{
  "name": "@open-practice/providers",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./automation": {
      "types": "./dist/automation.d.ts",
      "default": "./dist/automation.js"
    },
    "./draft-assist": {
      "types": "./dist/draft-assist.d.ts",
      "default": "./dist/draft-assist.js"
    },
    "./draft-exports": {
      "types": "./dist/draft-exports.d.ts",
      "default": "./dist/draft-exports.js"
    },
    "./email/imap": {
      "types": "./dist/email/imap.d.ts",
      "default": "./dist/email/imap.js"
    },
    "./email/parser": {
      "types": "./dist/email/parser.d.ts",
      "default": "./dist/email/parser.js"
    },
    "./email/smtp": {
      "types": "./dist/email/smtp.d.ts",
      "default": "./dist/email/smtp.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "default": "./dist/errors.js"
    },
    "./ocr/tesseract": {
      "types": "./dist/ocr/tesseract.d.ts",
      "default": "./dist/ocr/tesseract.js"
    },
    "./operations": {
      "types": "./dist/operations.d.ts",
      "default": "./dist/operations.js"
    },
    "./payments/stripe": {
      "types": "./dist/payments/stripe.d.ts",
      "default": "./dist/payments/stripe.js"
    },
    "./signatures": {
      "types": "./dist/signatures.d.ts",
      "default": "./dist/signatures.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "default": "./dist/testing.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@open-practice/domain": "workspace:*",
    "docx": "9.7.1",
    "imapflow": "^1.4.2",
    "mailparser": "^3.9.11",
    "nodemailer": "9.0.1",
    "pdfkit": "0.19.1",
    "stripe": "22.2.2",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/mailparser": "^3.4.6",
    "@types/nodemailer": "^8.0.1",
    "@types/pdfkit": "0.17.6",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0"
  }
}
