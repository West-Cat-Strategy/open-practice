{
  "name": "@open-practice/domain",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./participant-roles": {
      "types": "./dist/participant-roles.d.ts",
      "default": "./dist/participant-roles.js"
    },
    "./operational-actions": {
      "types": "./dist/operational-actions.d.ts",
      "default": "./dist/operational-actions.js"
    },
    "./calendar-models": {
      "types": "./dist/calendar-models.d.ts",
      "default": "./dist/calendar-models.js"
    },
    "./contact-models": {
      "types": "./dist/contact-models.d.ts",
      "default": "./dist/contact-models.js"
    },
    "./practice-presets": {
      "types": "./dist/practice-presets.d.ts",
      "default": "./dist/practice-presets.js"
    },
    "./sample-data": {
      "types": "./dist/sample-data.d.ts",
      "default": "./dist/sample-data.js"
    }
