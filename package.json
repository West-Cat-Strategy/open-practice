{
  "name": "open-practice",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.33.3",
  "pnpm": {
    "overrides": {
      "next>postcss": "8.5.10",
      "@esbuild-kit/core-utils>esbuild": "0.25.12",
      "fast-uri": "3.1.2"
    }
  },
  "scripts": {
    "build": "turbo build",
    "ci:local": "pnpm verify && git diff --check",
    "deps:audit": "pnpm audit --prod && pnpm audit --dev",
    "deps:licenses": "node scripts/report-dependency-licenses.mjs",
    "docs:check": "node scripts/validate-doc-links.mjs",
    "dev": "turbo dev --parallel",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "turbo lint",
    "policy:check": "pnpm security:scan && node scripts/validate-package-manifests.mjs && node scripts/validate-oss-reuse.mjs && node scripts/validate-doc-links.mjs && node scripts/validate-open-practice-boundaries.mjs",
    "release:local": "pnpm deps:audit && pnpm ci:local",
    "refs:clone": "node scripts/clone-oss-references.mjs",
    "security:scan": "node scripts/scan-tracked-secrets.mjs",
    "test": "turbo test && node --test scripts/*.test.mjs",
    "typecheck": "turbo typecheck",
    "verify:select": "node scripts/select-validation.mjs",
    "verify": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm --filter @open-practice/database db:check && pnpm policy:check && pnpm build"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@types/node": "25.8.0",
    "eslint": "10.4.0",
    "prettier": "3.8.3",
    "turbo": "2.9.14",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  }
}
