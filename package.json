{
  "name": "open-practice",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "packageManager": "pnpm@11.4.0",
  "scripts": {
    "build": "turbo build",
    "ci:local": "pnpm verify && git diff --check",
    "deps:audit": "pnpm audit --prod && pnpm audit --dev",
    "deps:licenses": "node scripts/report-dependency-licenses.mjs",
    "docs:check": "node scripts/validate-doc-links.mjs",
    "dev": "turbo dev --parallel",
    "e2e": "node scripts/run-e2e.mjs host",
    "e2e:docker": "node scripts/run-e2e.mjs docker",
    "e2e:host": "node scripts/run-e2e.mjs host",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "turbo lint",
    "migrations:check": "node scripts/check-migration-integrity.mjs",
    "migrations:replay": "node scripts/check-migration-integrity.mjs --mode replay",
    "policy:check": "pnpm security:scan && node scripts/validate-package-manifests.mjs && pnpm migrations:check && node scripts/validate-oss-reuse.mjs && node scripts/validate-doc-links.mjs && node scripts/validate-open-practice-boundaries.mjs",
    "playwright": "node scripts/run-e2e.mjs host",
    "release:evidence": "node scripts/write-release-evidence.mjs",
    "release:local": "node scripts/create-release-proof.mjs",
    "refs:clone": "node scripts/clone-oss-references.mjs",
    "security:scan": "node scripts/scan-tracked-secrets.mjs",
    "test": "turbo test && node --test scripts/*.test.mjs",
    "typecheck": "turbo typecheck",
    "verify:select": "node scripts/select-validation.mjs",
    "verify": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm --filter @open-practice/database db:check && pnpm policy:check && pnpm build"
  },
  "devDependencies": {
    "@cyclonedx/cyclonedx-npm": "4.2.1",
    "@playwright/test": "1.60.0",
    "@types/node": "25.9.1",
    "eslint": "10.4.0",
    "prettier": "3.8.3",
    "turbo": "2.9.15",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  }
}
